# MySQL connection string (Prisma 7 + MariaDB adapter)
# Use your local MySQL root password. MySQL 8 auth is handled via allowPublicKeyRetrieval in db-config.js.
DATABASE_URL="mysql://root:password@localhost:3306/immflow"

# Required in production — use a long random string (openssl rand -base64 32)
JWT_SECRET="immflow-local-development-secret-key-123456"

# Optional: public app URL for email links in auth flows
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: ngrok hostname when tunneling `npm run dev` (no https:// prefix)
# NGROK_HOST="your-subdomain.ngrok-free.dev"
