# MySQL connection string (Prisma 7 + MariaDB adapter)
DATABASE_URL="mysql://root:password@localhost:3306/immflow"

# Required in production — use a long random string (openssl rand -base64 32)
JWT_SECRET="immflow-local-development-secret-key-123456"

# Public app URL (password reset links, Stripe redirects)
# NEXT_PUBLIC_APP_URL="https://myimmflow.com"

# Email (Resend) — password reset & admin broadcasts
# EMAIL_API_KEY="re_..."
# EMAIL_FROM="ImmFlow <noreply@myimmflow.com>"
# EMAIL_PROVIDER=resend   # or zeptomail

# Stripe billing (Phase 2)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_ID="price_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Optional: ngrok hostname when tunneling `npm run dev` (no https:// prefix)
# NGROK_HOST="your-subdomain.ngrok-free.dev"
